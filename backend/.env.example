# EcoStay Environment Variables Example
# Duplicate this file as '.env' and fill in your actual credentials.

# Database URL for Supabase PostgreSQL (or any other Postgres instance)
# Format: postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-username:your-password@your-host:5432/postgres

# Flask secret key for session encryption (keep this secret in production!)
SECRET_KEY=eco-homestay-super-secret-key-12345
